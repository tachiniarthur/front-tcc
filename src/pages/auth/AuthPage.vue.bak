<template>
  <div class="min-h-screen flex">
    <PainelAuthComponent :title="isSignUp ? 'CADASTRAR' : 'ENTRAR'" :subtitle="isSignUp ? 'CRIAR CONTA' : 'ENTRAR'" />

    <div class="flex-1 bg-white text-gray-900 flex items-center justify-center p-8">
      <div class="w-full max-w-md">
        <div class="text-center mb-8">
          <GeometricLogo />
          <h2 class="text-3xl font-bold mt-3 text-gray-900">
            {{ isSignUp ? "CADASTRAR" : "ENTRAR" }}
          </h2>
        </div>

        <form class="space-y-6" @submit.prevent="handleSubmit">
          <template v-if="isSignUp">
            <div class="space-y-2">
              <label for="name" class="text-sm font-medium text-black">Nome completo</label>
              <div class="relative">
                <input id="name" type="text" placeholder="Digite seu nome completo" v-model="formData.name"
                  class="pl-4 h-12 w-full outline-none bg-transparent border-0 border-b-2 border-gray-200 rounded-none focus:border-gray-500 transition-colors" />
              </div>
            </div>

            <div class="space-y-2">
              <label for="username" class="text-sm font-medium text-black">Nome de usuário</label>
              <div class="relative">
                <input id="username" type="text" placeholder="Digite seu nome de usuário" v-model="formData.username"
                  class="pl-4 h-12 w-full outline-none bg-transparent border-0 border-b-2 border-gray-200 rounded-none focus:border-gray-500 transition-colors" />
              </div>
            </div>

            <div class="space-y-2">
              <label for="phone" class="text-sm font-medium text-black">Telefone</label>
              <div class="relative">
                <input id="phone" type="text" placeholder="Digite seu telefone" v-model="formData.phone"
                  class="pl-4 h-12 w-full outline-none bg-transparent border-0 border-b-2 border-gray-200 rounded-none focus:border-gray-500 transition-colors" />
              </div>
            </div>
          </template>

          <div class="space-y-2">
            <label for="email" class="text-sm font-medium text-black">E-mail</label>
            <div class="relative">
              <input id="email" type="email" placeholder="Digite seu e-mail" v-model="formData.email"
                class="pl-4 h-12 w-full outline-none bg-transparent border-0 border-b-2 border-gray-200 rounded-none focus:border-gray-500 transition-colors" />
            </div>
          </div>

          <div class="space-y-2">
            <label for="password" class="text-sm font-medium text-black">Senha</label>
            <div class="relative">
              <input id="password" :type="showPassword ? 'text' : 'password'" placeholder="Digite sua senha"
                v-model="formData.password"
                class="pl-4 pr-10 h-12 w-full outline-none bg-transparent border-0 border-b-2 border-gray-200 rounded-none focus:border-gray-500 transition-colors" />
              <button type="button" @click="showPassword = !showPassword"
                class="absolute right-3 top-3 text-black hover:text-gray-900 transition-colors"
                aria-label="Alternar visibilidade da senha">
                <font-awesome-icon :icon="showPassword ? 'eye-slash' : 'eye'" />
              </button>
            </div>
          </div>

          <template v-if="isSignUp">
            <div class="space-y-2">
              <label for="confirmPassword" class="text-sm font-medium text-black">Confirmar senha</label>
              <div class="relative">
                <input id="confirmPassword" :type="showConfirmPassword ? 'text' : 'password'"
                  placeholder="Confirme sua senha" v-model="formData.confirmPassword"
                  class="pl-4 pr-10 h-12 w-full outline-none bg-transparent border-0 border-b-2 border-gray-200 rounded-none focus:border-gray-500 transition-colors" />
                <button type="button" @click="showConfirmPassword = !showConfirmPassword"
                  class="absolute right-3 top-3 text-black hover:text-gray-900 transition-colors"
                  aria-label="Alternar visibilidade da senha">
                  <font-awesome-icon :icon="showConfirmPassword ? 'eye-slash' : 'eye'" />
                </button>
              </div>
            </div>
          </template>

          <div v-if="!isSignUp" class="text-right">
            <router-link :to="'/forget-password'"
              class="text-secondary-600 hover:text-secondary-700 text-sm transition-colors hover:cursor-pointer hover:underline">
              Esqueceu a senha?
            </router-link>
          </div>

          <button type="submit"
            class="w-full h-10 text-md font-semibold bg-black text-white hover:bg-gray-900 transition hover:cursor-pointer">
            {{ isSignUp ? "CADASTRAR" : "ENTRAR" }}
          </button>

          <div class="text-center">
            <span class="text-black/80 text-sm">
              {{ isSignUp ? "Já tem uma conta?" : "Não tem uma conta?" }}
            </span>
            <button type="button" @click="switchMode"
              class="ml-2 text-black font-medium text-sm transition-colors hover:cursor-pointer hover:underline">
              {{ isSignUp ? "Entrar" : "Cadastrar" }}
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</template>

<script setup>
import { reactive, ref, watch } from "vue";
import GeometricLogo from "@/components/auth/GeometricLogoComponent.vue";
import { useRoute, useRouter } from "vue-router";
import PainelAuthComponent from "@/components/auth/PainelAuthComponent.vue";
// AuthService no longer necessário: usamos o store para login/registro
import { useAuthStore } from '@/stores/auth';

const route = useRoute();
const router = useRouter();
const auth = useAuthStore();

const isSignUp = ref(route.name === "Cadastrar");
watch(
  () => route.name,
  (n) => {
    isSignUp.value = n === "Cadastrar";
  }
);

function switchMode() {
  router.push({ name: isSignUp.value ? "Entrar" : "Cadastrar" });
}

const showPassword = ref(false);
const showConfirmPassword = ref(false);

const formData = reactive({
  name: "",
  username: "",
  phone: "",
  email: "",
  password: "",
  confirmPassword: "",
});

function verifyData(data) {
  if (isSignUp.value) {
    return (
      data.name &&
      data.username &&
      data.phone &&
      data.email &&
      data.password &&
      data.confirmPassword
    );
  } else {
    return data.email && data.password;
  }
}

async function handleSubmit() {
  if (isSignUp.value) {
    if (formData.password !== formData.confirmPassword) {
      alert("As senhas não coincidem!");
      return;
    }

    if (!verifyData(formData)) {
      alert("Por favor, preencha todos os campos obrigatórios.");
      return;
    }

    try {
      await auth.registerWithCredentials({
        name: formData.name,
        username: formData.username,
        phone: formData.phone,
        email: formData.email,
        password: formData.password,
      })
      // registerWithCredentials redirects to home on success
    } catch (error) {
      const msg =
        error?.response?.data?.message ||
        error?.message ||
        "Erro ao cadastrar.";
      alert("Erro ao cadastrar: " + msg);
    }
  } else {
    if (!verifyData(formData)) {
      alert("Por favor, preencha e-mail e senha.");
      return;
    }

    try {
      // use auth store method that handles Sanctum token request
      await auth.loginWithCredentials({ email: formData.email, password: formData.password })
      // loginWithCredentials navigates to home on success
    } catch (error) {
      const msg =
        error?.response?.data?.message ||
        error?.message ||
        "Erro ao realizar login.";
      alert("Erro ao realizar login: " + msg);
    }
  }
}
</script>
