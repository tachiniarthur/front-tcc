import { defineStore } from 'pinia'
import http from '@/services/http'
import router from '@/router'

export const useAuthStore = defineStore('auth', {
  state: () => ({
    token: localStorage.getItem('token') || null,
    user: null,
  }),

  getters: {
    isLogged: (state) => !!state.token,
  },

  actions: {
    setToken(token) {
      this.token = token

      if (token) {
        localStorage.setItem('token', token)
      } else {
        localStorage.removeItem('token')
      }
    },

    setUser(user) {
      this.user = user
    },

    async loginWithCredentials({ email, password }) {
      // Use backend /login endpoint which returns { token }
      const payload = { email, password }

      const res = await http.post('/login', payload)

      const token = res.data?.token ?? (typeof res.data === 'string' ? res.data : null)
      if (!token) throw new Error('Token não retornado pelo servidor')

      this.setToken(token)

      // fetch logged user
      try {
        const userRes = await http.get('/api/user')
        this.setUser(userRes.data)
      } catch {
        // ignore user fetch errors
      }

      router.push({ name: 'Inicio' })
    },

    async registerWithCredentials(data) {
      // call createAccount controller endpoint
      // expect response: { message, user, token }
      const res = await http.post('/create-account', data)

      const token = res.data?.token ?? null
      const user = res.data?.user ?? null

      if (token) {
        this.setToken(token)
      }

      if (user) {
        this.setUser(user)
      } else {
        // try fetching user if not returned
        try {
          const userRes = await http.get('/api/user')
          this.setUser(userRes.data)
        } catch {
          // ignore
        }
      }

      router.push({ name: 'Inicio' })
    },

    async logout() {
      // try to invalidate token on server if endpoint exists
      try {
        await http.post('/logout')
      } catch {
        // ignore errors
      }

      this.setToken(null)
      this.setUser(null)
      router.push({ name: 'Entrar' })
    },

    async checkAuth() {
      const token = localStorage.getItem('token')

      if (!token) {
        this.setToken(null)
        this.setUser(null)
        return false
      }

      this.token = token

      try {
        const userRes = await http.get('/api/user')
        this.user = userRes.data
      } catch {
        // token may be invalid; clear
        this.setToken(null)
        this.setUser(null)
        return false
      }

      return true
    },
  },
})
